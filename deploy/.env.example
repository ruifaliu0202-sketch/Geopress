# Copy this file to .env before deployment and change every placeholder secret.

# Public ports exposed by docker compose.
WEB_PORT=80
API_PORT=18080

# Default: connect from Docker containers to PostgreSQL running on the host at localhost:5432.
DATABASE_URL=postgres://geo_app:geo_app_dev_password@host.docker.internal:5432/geo?sslmode=disable

# Only used by the bundled PostgreSQL service.
POSTGRES_USER=geo_app
POSTGRES_PASSWORD=geo_app_dev_password
POSTGRES_DB=geo
POSTGRES_PORT=5432

# Browser/API origins.
FRONTEND_ORIGIN=http://localhost

# AI provider.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
AI_REQUEST_TIMEOUT_SECONDS=45

# Xiaohongshu browser automation.
GEOPRESS_BROWSER_HEADLESS=true
GEOPRESS_CHROMIUM_NO_SANDBOX=true

# Image tag suffix for local builds.
GEOPRESS_IMAGE_TAG=local
